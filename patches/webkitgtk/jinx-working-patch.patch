+WTF_ALLOW_UNSAFE_BUFFER_USAGE_BEGIN
+    void* zinniaBound = static_cast<char*>(origin) - zinniaStackSize;
+WTF_ALLOW_UNSAFE_BUFFER_USAGE_END
+    return StackBounds { origin, zinniaBound };
+#else
     void* bound = nullptr;
     size_t stackSize = 0;
 
