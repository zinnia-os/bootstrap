<?xml version="1.0" encoding="UTF-8"?>
<!--
  System default xfwm4 settings for Zinnia.  Compositing is disabled because
  there is no hardware GL on virtio-gpu (everything renders via llvmpipe /
  software Xrender), so the compositor only adds per-frame CPU overhead and
  makes the desktop sluggish.  Users can re-enable it in Window Manager Tweaks.
-->
<channel name="xfwm4" version="1.0">
  <property name="general" type="empty">
    <property name="use_compositing" type="bool" value="false"/>
  </property>
</channel>
